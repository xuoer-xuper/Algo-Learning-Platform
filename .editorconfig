root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.{png,jpg,jpeg,gif,ico,pdf,zip,asar}]
insert_final_newline = false
trim_trailing_whitespace = false

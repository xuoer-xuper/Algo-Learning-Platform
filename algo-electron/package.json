{
  "name": "algo-electron",
  "private": true,
  "version": "0.6.0",
  "description": "Local-first algorithm learning tracker desktop app",
  "author": "Algo Learning Platform Contributors",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win nsis",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "node tests/run-tests.mjs core",
    "test:core": "node tests/run-tests.mjs core",
    "test:architecture": "node tests/run-tests.mjs architecture",
    "test:security": "node tests/run-tests.mjs security",
    "test:adapters": "node tests/run-tests.mjs adapters",
    "test:submissions": "node tests/run-tests.mjs submissions",
    "test:db": "node tests/run-tests.mjs db",
    "test:docs": "node tests/run-tests.mjs docs",
    "test:packaging": "node tests/run-tests.mjs packaging",
    "test:electron": "node tests/run-tests.mjs electron",
    "test:ui": "node tests/run-tests.mjs ui",
    "test:all": "node tests/run-tests.mjs all"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "better-sqlite3": "^12.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
